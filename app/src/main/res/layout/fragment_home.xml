<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8EC">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/starfish"
        android:text="MOCHI"
        android:textColor="#1A00C896"
        android:textSize="120sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="-20dp"
        android:layout_marginEnd="-30dp" />

    <ImageView
        android:id="@+id/ic_settings"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:src="@drawable/ic_settings"
        android:contentDescription="Settings"
        android:clickable="true"
        android:focusable="true"
        android:elevation="10dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/aber"
                android:text="HOLA,"
                android:textColor="#00C896"
                android:letterSpacing="0.2"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/starfish"
                android:text="Welcome\nBack!"
                android:textColor="@color/black"
                android:textSize="40sp"
                android:layout_marginTop="2dp"/>

            <View
                android:layout_width="50dp"
                android:layout_height="4dp"
                android:background="#00C896"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="25dp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:alignmentMode="alignBounds"
                android:columnOrderPreserved="false">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRumusBangunRuang"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:backgroundTint="#00C896"
                    android:fontFamily="@font/starfish"
                    android:text="📐 Geometry\nCalc"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    app:cornerRadius="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnJobBoard"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:backgroundTint="#FFF8EC"
                    android:fontFamily="@font/starfish"
                    android:text="🎮 Career\nPath"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:textColor="#00C896"
                    app:cornerRadius="16dp"
                    app:strokeColor="#00C896"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPortofolio"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:backgroundTint="#FFF8EC"
                    android:fontFamily="@font/starfish"
                    android:text="✨ Best\nProjects"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:textColor="#00C896"
                    app:cornerRadius="16dp"
                    app:strokeColor="#00C896"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWebBinaDesa"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:backgroundTint="#00C896"
                    android:fontFamily="@font/starfish"
                    android:text="🌐 Fasilitas\nDesa"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    app:cornerRadius="16dp" />

            </GridLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="35dp"
                android:layout_marginBottom="12dp"
                android:background="#1500C896"
                android:paddingVertical="8dp"
                android:paddingHorizontal="16dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/starfish"
                    android:text="Activity Feed"
                    android:textColor="#00C896"
                    android:textSize="20sp" />
            </LinearLayout>

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayoutFeed"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#FDF2E2"
                app:tabBackground="?attr/selectableItemBackground"
                app:tabRippleColor="#2200C896"
                app:tabTextColor="#8A8A8A"
                app:tabSelectedTextColor="#00C896"
                app:tabIndicatorColor="#00C896"
                app:tabIndicatorHeight="3dp"
                app:tabIndicatorFullWidth="false"
                app:tabInlineLabel="true"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1100C896">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/viewPagerFeed"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="4dp" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="35dp"
                android:fontFamily="@font/aber"
                android:text="BERITA PUBLIK TERKINI"
                android:textColor="#00C896"
                android:letterSpacing="0.1"
                android:textSize="12sp"
                android:textStyle="bold" />

            <View
                android:layout_width="35dp"
                android:layout_height="3dp"
                android:background="#00C896"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvNews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="35dp"
                android:layout_marginBottom="20dp"
                android:fontFamily="@font/aber"
                android:text="Sign Out"
                android:textColor="#6F4E37"
                app:cornerRadius="15dp"
                app:strokeColor="#6F4E37"
                app:strokeWidth="1dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>