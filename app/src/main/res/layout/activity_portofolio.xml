<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8EC"> <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="REX"
    android:fontFamily="@font/starfish"
    android:textSize="200sp"
    android:textColor="#1000C896"
    android:rotation="-15"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:layout_marginBottom="-50dp"
    android:layout_marginEnd="-40dp"/>

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="30dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EST. 2026"
            android:fontFamily="@font/aber"
            android:textColor="#00C896"
            android:letterSpacing="0.2"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvJudulPortofolio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/starfish"
            android:text="Creative\nShowcase"
            android:textColor="@color/black"
            android:textSize="55sp"
            android:lineHeight="50dp"
            android:layout_marginTop="10dp"/>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/contentCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="30dp"
        app:cardCornerRadius="35dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#1000C896"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="35dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ABOUT PROJECT"
                android:fontFamily="@font/aber"
                android:textColor="@color/black"
                android:textSize="10sp"
                android:alpha="0.5"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tvDeskripsiPortofolio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:fontFamily="@font/aber"
                android:text="Transforming ideas into digital reality. We build experiences that define the future of gaming culture."
                android:textColor="@color/black"
                android:textSize="18sp"
                android:lineSpacingExtra="8dp" />

            <View
                android:layout_width="50dp"
                android:layout_height="4dp"
                android:background="#00C896"
                android:layout_marginTop="25dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="30dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Explore our latest\nworks online."
            android:fontFamily="@font/aber"
            android:textSize="14sp"
            android:textColor="#555555"/>

        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/btnTambahPortofolio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter"
            android:fontFamily="@font/starfish"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:backgroundTint="#00C896"
            app:icon="@drawable/eye"
            app:iconTint="@color/white" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>