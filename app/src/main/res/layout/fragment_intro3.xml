<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#FFF8EC">

    <ImageView
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:src="@android:drawable/ic_dialog_dialer"
        android:tint="#00C896" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/starfish"
        android:text="Mulai Eksplorasi!"
        android:textColor="#00C896"
        android:textSize="28sp"
        android:layout_marginTop="32dp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:fontFamily="@font/aber"
        android:text="Nikmati kemudahan akses seluruh fitur andalan Mochi dalam satu aplikasi."
        android:textColor="#666666"
        android:textSize="16sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStart"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="40dp"
        android:backgroundTint="#00C896"
        android:fontFamily="@font/aber"
        android:text="Ayo Mulai"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />
</LinearLayout>