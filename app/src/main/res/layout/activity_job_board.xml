<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8EC"> <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:fontFamily="@font/starfish"
    android:rotation="90"
    android:text="JOB"
    android:textColor="#1000C896"
    android:textSize="180sp"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    android:layout_marginStart="-60dp"
    android:layout_marginBottom="100dp" />

    <LinearLayout
        android:id="@+id/topSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="30dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/aber"
            android:letterSpacing="0.2"
            android:text="Hiring Now"
            android:textColor="#00C896"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvJudulJob"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/starfish"
            android:text="Career\nPath"
            android:textColor="@color/black"
            android:textSize="55sp"
            android:lineHeight="52dp"/>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="30dp"
        app:cardBackgroundColor="#1000C896"
        app:cardCornerRadius="35dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/topSection">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="30dp">

            <ImageView
                android:id="@+id/ivIconJob"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/rexlogo"
                android:layout_marginBottom="20dp" />

            <TextView
                android:id="@+id/tvDeskripsiJob"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/aber"
                android:lineSpacingExtra="6dp"
                android:text="Join our elite team and shape the future of Rexodus Gaming. We are looking for passionate souls."
                android:textColor="@color/black"
                android:textSize="18sp" />

            <View
                android:layout_width="60dp"
                android:layout_height="4dp"
                android:layout_marginTop="25dp"
                android:background="#00C896" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="30dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApply"
            android:layout_width="match_parent"
            android:layout_height="75dp"
            android:backgroundTint="#00C896"
            android:fontFamily="@font/starfish"
            android:text="Apply Position ✨"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="22sp"
            app:cornerRadius="25dp"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>