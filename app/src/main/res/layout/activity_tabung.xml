<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8EC"> <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:fontFamily="@font/starfish"
    android:text="3.14"
    android:textColor="#1000C896"
    android:textSize="180sp"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:layout_marginEnd="-40dp"
    android:layout_marginBottom="-40dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="30dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/aber"
            android:text="← BACK"
            android:textColor="#00C896"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:fontFamily="@font/starfish"
            android:text="Volume\nTabung"
            android:textColor="@color/black"
            android:textSize="50sp"
            android:lineHeight="48dp" />

        <View
            android:layout_width="50dp"
            android:layout_height="6dp"
            android:background="#00C896"
            android:layout_marginTop="10dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            app:cardCornerRadius="25dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1000C896"> <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RADIUS (r)"
                android:fontFamily="@font/aber"
                android:textSize="10sp"
                android:alpha="0.6"
                android:letterSpacing="0.1"/>

            <EditText
                android:id="@+id/etRadius"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@null"
                android:hint="0"
                android:inputType="numberDecimal"
                android:fontFamily="@font/aber"
                android:textSize="20sp"
                android:textColor="@color/black"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#3000C896"
                android:layout_marginVertical="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TINGGI (t)"
                android:fontFamily="@font/aber"
                android:textSize="10sp"
                android:alpha="0.6"
                android:letterSpacing="0.1"/>

            <EditText
                android:id="@+id/etTinggi"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@null"
                android:hint="0"
                android:inputType="numberDecimal"
                android:fontFamily="@font/aber"
                android:textSize="20sp"
                android:textColor="@color/black" />
        </LinearLayout>
        </androidx.cardview.widget.CardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHitungVolume"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginTop="30dp"
            android:backgroundTint="#00C896"
            android:fontFamily="@font/starfish"
            android:text="CALCULATE ✨"
            android:textAllCaps="false"
            android:textSize="22sp"
            app:cornerRadius="20dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="#F8F0E5"
            app:cardCornerRadius="25dp"
            app:cardElevation="0dp"
            app:strokeColor="#00C896"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RESULT"
                    android:fontFamily="@font/aber"
                    android:textSize="12sp"
                    android:alpha="0.5"
                    android:letterSpacing="0.2"/>

                <TextView
                    android:id="@+id/tvHasil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/starfish"
                    android:text="0.00"
                    android:textColor="#008F6B"
                    android:textSize="45sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>